# ─────────────────────────────────────────────────────────
# .gitignore — Baarako Card (Next.js + Prisma + Supabase)
# ─────────────────────────────────────────────────────────

# ── Dépendances Node.js ──────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────
.next/
out/
/build

# ── Prisma ───────────────────────────────────────────────
# Ne pas committer les migrations générées automatiquement
# (garder prisma/migrations/ si vous voulez tracer l'historique)
prisma/generated/

# ── Variables d'environnement (DONNÉES SENSIBLES) ────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Garder .env.example (template non-secret) : ne pas l'ignorer

# ── Tests & Coverage ─────────────────────────────────────
/coverage
*.lcov

# ── Système d'exploitation ───────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Éditeurs & IDE ───────────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# ── Vercel / Déploiement ─────────────────────────────────
.vercel

# ── Divers ───────────────────────────────────────────────
*.pem
.cache/
dist/
